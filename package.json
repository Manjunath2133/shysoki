{
  "name": "shyoski",
  "version": "1.0.0",
  "description": "System background maintenance service",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:all": "electron-builder --mac --win"
  },
  "dependencies": {
    "@deepgram/sdk": "^3.13.0",
    "@google/generative-ai": "^0.21.0",
    "axios": "^1.16.0",
    "dotenv": "^16.4.5",
    "electron-is-dev": "^2.0.0",
    "groq-sdk": "^1.1.2",
    "openai": "^6.35.0",
    "screenshot-desktop": "^1.12.7",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.15.2"
  },
  "build": {
    "appId": "com.shyoski.pilot",
    "productName": "Shyoski",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "scripts/**/*",
      "package.json",
      "eng.traineddata"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
